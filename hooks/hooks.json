{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-claude-dir-commit.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-coauthor-commit.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/enforce-conventional-commit.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/require-review-before-ship.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/require-tests-before-ship.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/require-pr-green-before-merge.sh"], "timeout": 15 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/require-codereviewer-verdict-before-merge.sh"], "timeout": 15 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/enforce-delete-branch-on-merge.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-pr-merge-stale-base.sh"], "timeout": 15 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/remind-walk-before-next-merge.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/require-backlog-reconciled-before-merge.sh"], "timeout": 15 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-compound-commit-push.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-non-lead-git-push-merge.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-multi-worktree-per-wave.sh"], "timeout": 8 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-pnpm-install-in-main.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-cleaned-data-commit.sh"], "timeout": 10 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-truncate-existing-ledger.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/require-oplog-row-for-this-merge.sh"], "timeout": 10 }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-bare-agent.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/validate-agent-type.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-non-codereviewer-mode-b.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-spawn-over-roster-cap.sh"], "timeout": 8 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/enforce-planner-first.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/backlog-sop-validate.sh", "--mode", "pre-dispatch"], "timeout": 10 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/backlog-sop-validate.sh", "--mode", "pre-review"], "timeout": 10 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-codereviewer-for-plan-review.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/require-stallcheck-cron-before-dispatch.sh"], "timeout": 8 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/require-premise-verified-before-dev.sh"], "timeout": 8 }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-lead-plan-approval-response.sh"], "timeout": 5 }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-backlog-status-drift.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-malformed-new-backlog-card.sh"], "timeout": 10 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/block-lead-editing-source.sh"], "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/loop-detection.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/post-merge-cleanup-reminder.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/remind-shutdown-done-agent.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/post-pr-merge-walk-reminder.sh"], "timeout": 5 }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/remind-dispatch-reviewer-after-dev.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/prune-team-inboxes.sh"], "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/pipeline-reminder.sh"], "timeout": 5 },
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/startup-context.sh"], "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/stop-dispatcher.sh"], "timeout": 45 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/preflight.sh"], "timeout": 5 }
        ]
      }
    ]
  }
}
